<mxfile host="app.diagrams.net" agent="Claude" version="24.0.0">
  <diagram id="simulspeak-frontend" name="前端结构图">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题 -->
        <mxCell id="title" value="SimulSpeak 前端结构图（SPA：TypeScript + React + Vite）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="780" height="30" as="geometry" />
        </mxCell>

        <!-- ============ App 根 ============ -->
        <mxCell id="app" value="App.tsx&#10;(应用根 / 布局装配)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="320" y="70" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- ============ UI 组件层 ============ -->
        <mxCell id="uiGroup" value="UI 组件层 (src/components)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=12;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="160" width="800" height="120" as="geometry" />
        </mxCell>
        <mxCell id="topbar" value="TopBar.tsx&#10;顶栏：连接状态 / 延迟估计 / 会话·utteranceId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="195" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="controlbar" value="ControlBar.tsx&#10;控制栏：音频源 / 策略下拉 / 配音开关 / 开始·停止" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="255" y="195" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="subpanel" value="SubtitlePanel.tsx ★核心&#10;双语字幕面板：按 utteranceId 分块&#10;灰/黑/纠错高亮 · 🔒锁定 · 自动滚动" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="195" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="bottombar" value="BottomBar.tsx (加分)&#10;导出 SRT/TXT · 要点总结 · 术语表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="655" y="195" width="165" height="70" as="geometry" />
        </mxCell>

        <!-- ============ 编排层 ============ -->
        <mxCell id="session" value="useSession.ts — 会话编排 (src/session)&#10;串联生命周期：开始 / 停止 / 运行时策略切换；驱动 WS+RTC 握手，回推渲染" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="180" y="330" width="520" height="60" as="geometry" />
        </mxCell>

        <!-- ============ 状态层 ============ -->
        <mxCell id="store" value="subtitles.ts — 字幕状态 (src/state, zustand)&#10;Map&lt;utteranceId, SubtitleLine&gt; + 有序列表&#10;渲染规则：partial→灰 / final→黑锁定 / revised→纠错高亮；节流防抖；保留最近 50 条" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="180" y="440" width="520" height="70" as="geometry" />
        </mxCell>

        <!-- ============ 客户端层 ============ -->
        <mxCell id="clientGroup" value="网络客户端层" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;fontStyle=1;fontSize=12;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="560" width="560" height="130" as="geometry" />
        </mxCell>
        <mxCell id="wsclient" value="WsClient.ts — WS 控制客户端 (src/ws)&#10;连接 /ws?token · JSON 编解码 · requestId&#10;ping/pong 心跳 · client_hello 握手&#10;消息分发：asr_result / translation_result / answer / ice / error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="595" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rtcclient" value="RtcClient.ts — WebRTC 媒体客户端 (src/rtc)&#10;采集音频 track(getUserMedia / getDisplayMedia)&#10;RTCPeerConnection · createOffer · answer · ice&#10;ontrack → &lt;audio autoplay&gt; 播放中文配音" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="450" y="595" width="250" height="80" as="geometry" />
        </mxCell>

        <!-- ============ 基础层 ============ -->
        <mxCell id="protocol" value="types/protocol.ts&#10;WS 全量消息类型 + SubtitleLine&#10;Strategy / SubtitleStatus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="730" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="config" value="config.ts&#10;env: VITE_WS_URL / tenantId / clientId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="730" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- ============ 外部服务 ============ -->
        <mxCell id="extGroup" value="外部 / 浏览器侧" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontStyle=1;fontSize=12;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="330" width="250" height="360" as="geometry" />
        </mxCell>
        <mxCell id="wsserver" value="后端 WS 信令服务&#10;ws://{host}/ws&#10;(connected / hello_ack / answer / ice&#10; asr_result / translation_result / tts)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="370" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="webrtc" value="WebRTC 媒体通道&#10;上行：英文音频 track&#10;下行：中文 TTS 配音 track" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="475" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="media" value="浏览器媒体 API&#10;getUserMedia / getDisplayMedia&#10;&lt;audio&gt; 配音播放" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="565" width="210" height="70" as="geometry" />
        </mxCell>

        <!-- ============ 连接边 ============ -->
        <!-- App 装配 UI -->
        <mxCell id="e_app_top" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;strokeColor=#b85450;" edge="1" parent="1" source="app" target="topbar"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_app_ctrl" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;strokeColor=#b85450;" edge="1" parent="1" source="app" target="controlbar"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_app_sub" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;strokeColor=#b85450;" edge="1" parent="1" source="app" target="subpanel"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_app_bot" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;strokeColor=#b85450;" edge="1" parent="1" source="app" target="bottombar"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ControlBar -> useSession (start/stop/strategy) -->
        <mxCell id="e_ctrl_session" value="开始/停止/切策略" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#9673a6;fontSize=10;" edge="1" parent="1" source="controlbar" target="session"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- store -> SubtitlePanel (subscribe) -->
        <mxCell id="e_store_sub" value="订阅渲染" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;" edge="1" parent="1" source="store" target="subpanel"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- store -> TopBar (status/latency) -->
        <mxCell id="e_store_top" value="状态/延迟" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;dashed=1;" edge="1" parent="1" source="store" target="topbar"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- session -> clients -->
        <mxCell id="e_session_ws" value="握手/收发" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#9673a6;fontSize=10;" edge="1" parent="1" source="session" target="wsclient"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_session_rtc" value="采集/连接" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#9673a6;fontSize=10;" edge="1" parent="1" source="session" target="rtcclient"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- wsclient -> store (dispatch asr/translation) -->
        <mxCell id="e_ws_store" value="asr/translation 帧&#10;→ upsert 字幕" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#d79b00;fontSize=10;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.25;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="wsclient" target="store"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- wsclient <-> rtcclient (sdp/ice relay via ws) -->
        <mxCell id="e_ws_rtc" value="offer/answer/ice 经 WS 转发" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=block;endArrow=block;strokeColor=#d79b00;fontSize=10;" edge="1" parent="1" source="wsclient" target="rtcclient"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- clients -> external -->
        <mxCell id="e_ws_server" value="WebSocket" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=block;endArrow=block;strokeColor=#d6b656;fontSize=10;" edge="1" parent="1" source="wsclient" target="wsserver"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_rtc_peer" value="SRTP 音频" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=block;endArrow=block;strokeColor=#d6b656;fontSize=10;" edge="1" parent="1" source="rtcclient" target="webrtc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_rtc_media" value="track/播放" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=block;endArrow=block;strokeColor=#d6b656;fontSize=10;" edge="1" parent="1" source="rtcclient" target="media"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- foundation used by clients/store -->
        <mxCell id="e_proto_ws" value="类型约束" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;dashed=1;strokeColor=#666666;fontSize=10;" edge="1" parent="1" source="protocol" target="wsclient"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_config_session" value="读取 env" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;dashed=1;strokeColor=#666666;fontSize=10;" edge="1" parent="1" source="config" target="rtcclient"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 图例 -->
        <mxCell id="legend" value="数据流：控制栏 → useSession 编排 → WS/RTC 客户端 →（WsClient 分发 asr/translation 帧）→ 字幕状态 store → SubtitlePanel 渲染；音频经 WebRTC 上行(英文)/下行(中文配音)。虚线分组框为分层；BottomBar/基础层为加分或基础设施。" style="text;html=1;strokeColor=#999999;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=11;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="800" width="1090" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
