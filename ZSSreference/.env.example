# SimulSpeak 运行配置模板。复制为 .env 后按需修改：cp .env.example .env
#
# 加载优先级（后者覆盖前者）：内置默认值 → YAML(--config) → .env / 环境变量 → 命令行参数。
# 注意：进程中已显式设置的环境变量优先于本文件，不会被 .env 覆盖。
# .env 已被 .gitignore 忽略，请勿提交真实密钥。

# ---- 服务 ----
SIMULSPEAK_SERVICE_NAME=api-server

# ---- 监听地址 ----
SIMULSPEAK_HTTP_ADDRESS=0.0.0.0:8080
SIMULSPEAK_GRPC_ADDRESS=0.0.0.0:9090

# ---- 控制面存储 etcd（逗号分隔多个 endpoint）----
# memory=本地单进程开发/单测；etcd=跨进程/多 PBX 节点服务发现
SIMULSPEAK_ETCD_MODE=memory
SIMULSPEAK_ETCD_ENDPOINTS=http://127.0.0.1:2379

# ---- PBX 内部控制通道 / 节点注册 ----
SIMULSPEAK_PBX_CONTROL_ADDRESS=0.0.0.0:8081
SIMULSPEAK_PBX_NODE_WS_URL=ws://127.0.0.1:8081/pbx/ws
# 本 PBX 节点 WebRTC ICE UDP 端口范围。单机启动多个 pbx-node 压测时，每个节点应使用不同范围。
SIMULSPEAK_PBX_WEBRTC_UDP_PORT_MIN=20000
SIMULSPEAK_PBX_WEBRTC_UDP_PORT_MAX=20100
# pbx-node 自注册到 registry 的 media 节点信息。生产多节点时 advertise 必须是 api-server 可访问的 WS 地址。
SIMULSPEAK_NODE_ID=
SIMULSPEAK_NODE_ADVERTISE=ws://127.0.0.1:8081/pbx/ws
SIMULSPEAK_NODE_ZONE=default
SIMULSPEAK_NODE_MAX_CALLS=100
SIMULSPEAK_NODE_WEIGHT=1

# ---- 持久化 / 缓存 / 消息 ----
SIMULSPEAK_SQLITE_DSN='file:./data/simulspeak.db?_pragma=busy_timeout(5000)&_pragma=journal_mode(WAL)'
SIMULSPEAK_REDIS_ADDRESS=127.0.0.1:6379
SIMULSPEAK_NATS_URL=nats://127.0.0.1:4222

# ---- PBX 录音（默认关闭；开启后 pbx-node 将上行 WebRTC 音频保存为 WAV）----
SIMULSPEAK_RECORDING_ENABLED=0
SIMULSPEAK_RECORDING_DIR=./data/recordings
SIMULSPEAK_RECORDING_SAMPLE_RATE=16000

# ---- 鉴权密钥（生产务必修改；留空表示不启用）----
SIMULSPEAK_JWT_SECRET=

# ---- AI Provider ----
SIMULSPEAK_ASR_PROVIDER=mock
SIMULSPEAK_TMT_PROVIDER=mock
SIMULSPEAK_TTS_PROVIDER=mock

# 腾讯云 ASR/TMT/TTS 按 provider + capability 分开配置。
SIMULSPEAK_TENCENT_ASR_ENDPOINT=wss://asr.cloud.tencent.com/asr/v2
SIMULSPEAK_TENCENT_ASR_APPID=
SIMULSPEAK_TENCENT_ASR_SECRETID=
SIMULSPEAK_TENCENT_ASR_SECRETKEY=
SIMULSPEAK_TENCENT_TMT_ENDPOINT=https://tmt.tencentcloudapi.com
SIMULSPEAK_TENCENT_TMT_REGION=ap-guangzhou
SIMULSPEAK_TENCENT_TMT_PROJECT_ID=0
SIMULSPEAK_TENCENT_TMT_SECRETID=
SIMULSPEAK_TENCENT_TMT_SECRETKEY=
SIMULSPEAK_TENCENT_TTS_ENDPOINT=https://tts.tencentcloudapi.com
SIMULSPEAK_TENCENT_TTS_APPID=
SIMULSPEAK_TENCENT_TTS_SECRETID=
SIMULSPEAK_TENCENT_TTS_SECRETKEY=

# ---- LLM 校对/重译（OpenAI-compatible Chat Completions；默认不启用 live test）----
SIMULSPEAK_LLM_PROVIDER=openai-compatible
SIMULSPEAK_LLM_ENDPOINT=
SIMULSPEAK_LLM_API_KEY=
SIMULSPEAK_LLM_MODEL=
SIMULSPEAK_LLM_LIVE_TEST=0

# ---- 异步单词本 worker ----
SIMULSPEAK_WORKER_ID=vocabulary-worker
SIMULSPEAK_WORKER_NODE_ID=
SIMULSPEAK_WORKER_CONCURRENCY=1
SIMULSPEAK_WORKER_POLL_INTERVAL=1s
SIMULSPEAK_VOCAB_LLM_TIMEOUT=30s
SIMULSPEAK_VOCAB_TASK_LOCK_TIMEOUT=5m
SIMULSPEAK_VOCAB_TASK_MAX_ATTEMPTS=3

# ---- VAD（simple=纯能量法；silero=ONNX 推理）----
SIMULSPEAK_VAD_PROVIDER=silero
SIMULSPEAK_VAD_MODEL_PATH=./third_party/silero-vad/silero_vad.onnx
SIMULSPEAK_VAD_SAMPLE_RATE=16000
# Silero 需要 ONNX Runtime 动态库路径（以下两个变量名等价，任填其一）
SIMULSPEAK_VAD_RUNTIME_LIBRARY_PATH=./third_party/onnxruntime-linux-x64-1.26.0/lib/libonnxruntime.so.1.26.0
# SIMULSPEAK_ONNX_RUNTIME_LIBRARY_PATH=./third_party/onnxruntime-linux-x64-1.26.0/lib/libonnxruntime.so.1.26.0
